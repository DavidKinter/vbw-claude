{
  "vbw": {
    "sandbox_path": "/tmp/vbw-sandbox",
    "max_iterations": 5,
    "parallel_execution": false,
    "auto_cleanup": true,
    "verbose_logging": true,
    "excluded_patterns": [
      ".git",
      ".env",
      ".env.*",
      "*.env",
      "credentials*",
      "secrets*",
      "*.pem",
      "*.key",
      "__pycache__",
      ".venv",
      "*.pyc",
      ".pytest_cache",
      "node_modules",
      "target",
      "dist",
      "build",
      ".next",
      "vendor"
    ],
    "error_patterns": {
      "description": "Language-specific error pattern files for diagnosis",
      "pattern_files": "settings/vbw-error-patterns-{language}.json",
      "available_languages": ["python", "typescript", "go", "java", "csharp", "ruby", "php", "rust", "swift", "kotlin", "cpp"],
      "auto_detect": true,
      "detection_rules": {
        "python": ["pyproject.toml", "setup.py", "requirements.txt", "*.py"],
        "typescript": ["package.json", "tsconfig.json", "*.ts", "*.tsx"],
        "go": ["go.mod", "go.sum", "*.go"],
        "java": ["pom.xml", "build.gradle", "*.java"],
        "csharp": ["*.csproj", "*.sln", "*.cs"],
        "ruby": ["Gemfile", "Rakefile", "*.rb"],
        "php": ["composer.json", "*.php"],
        "rust": ["Cargo.toml", "*.rs"],
        "swift": ["Package.swift", "*.swift", "*.xcodeproj"],
        "kotlin": ["build.gradle.kts", "*.kt", "*.kts"],
        "cpp": ["CMakeLists.txt", "Makefile", "*.cpp", "*.c", "*.h", "*.hpp"]
      }
    },
    "live_api_validation": {
      "enabled": true,
      "retry_count": 3,
      "retry_delay_seconds": 5,
      "soft_fail_on_connectivity": true,
      "request_timeout_seconds": 15,
      "indicators": [
        "import requests",
        "import httpx",
        "import aiohttp",
        "import urllib",
        "@responses.activate",
        "responses.get(",
        "responses.post(",
        "httpretty",
        "https://",
        "http://"
      ],
      "skip_patterns": [
        "localhost",
        "127.0.0.1",
        "0.0.0.0"
      ],
      "verdicts": {
        "pass": ["MATCH", "CONFIRMED", "PARTIAL", "UNREACHABLE"],
        "block": ["MISMATCH"]
      },
      "marker_files": {
        "endpoints": ".vbw-live-validation-endpoints",
        "result": ".vbw-live-validation-result"
      }
    }
  }
}
